connectivity_policy {
    allow_deployments_to_no_targets = true
}

versioning_strategy {
    template = "#{Octopus.Version.Channel.LastMajor}.#{Octopus.Version.Channel.LastMinor}.#{Octopus.Version.Channel.NextPatch}#{if Octopus.Release.Channel.Name != \"Production\"}-#{Octopus.Release.Channel.Name | ToLower | Replace \" \" \"-\"}#{/if}"
}